#!/bin/bash

chromium-browser --noerrdialogs \
                 --incognito \
                 --kiosk {{ chromium_url_url }} \
                 --force-device-scale-factor={{ chromium_url_scale_factor }} \
                 --disable-infobars &

sleep 20 && xdotool search "{{ chromium_windowname }}" windowactivate --sync key --clearmodifiers key KP_Enter
